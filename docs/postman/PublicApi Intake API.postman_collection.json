{
  "info": {
    "_postman_id": "c3d4e5f6-a7b8-9012-cdef-234567890123",
    "name": "Public API Submissions",
    "description": "Post forms to the Public API guest endpoint. Use with **Public API Environment (Dev Scratch Org)**, **Public API Environment (Beta)**, or **Public API Environment (Production)**.\n\n**URL:** Requests use `{{base_url}}/{{rest_path}}/v1/publicapi/submissions`. Use `services/apexrest` for `rest_path`. Set **base_url** to your site root, including any site path prefix such as `/api`.\n\n**Auth:** Send **X-Api-Key** on every request. The value must match exactly one active Public API Integration Config record.\n\n**Setup:** Create one or more active Public API Integration Config records with unique API keys. The matched record determines signature verification and outbound status update routing.\n\n**Mapped fields:** Controlled from the Request Builder and persisted in `Outbound_Payload_Configuration__c` using object references such as `$PublicApi_Submission__c.Email__c`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Submission",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has recordId\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('recordId');",
              "    pm.environment.set('record_id', jsonData.recordId);",
              "});",
              "",
              "pm.test(\"Success message returned\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.eql('Submission created successfully');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json", "type": "text"},
          {"key": "X-Api-Key", "value": "{{api_key}}", "type": "text", "description": "Required. Must match exactly one active Public API Integration Config record."}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"jane.smith@example.com\",\n  \"name\": \"Jane\",\n  \"last_name\": \"Smith\",\n  \"phone_number\": \"(555) 123-4567\",\n  \"page_url\": \"https://example.com/landing\",\n  \"utm_source\": \"google\",\n  \"campaignid\": \"summer-2025\",\n  \"utm_medium\": \"cpc\",\n  \"utm_content\": \"ad-variant-a\",\n  \"description\": \"Lead from landing page\",\n  \"gclid\": \"test-gclid\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/{{rest_path}}/v1/publicapi/submissions",
          "host": ["{{base_url}}"],
          "path": ["{{rest_path}}", "v1", "publicapi", "submissions"]
        }
      },
      "description": "Creates a submission with canonical key/value payload fields."
    },
    {
      "name": "Create Submission (with data wrapper)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response has recordId\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('recordId');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json", "type": "text"},
          {"key": "X-Api-Key", "value": "{{api_key}}", "type": "text"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": {\n    \"email\": \"john.doe@example.com\",\n    \"name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone_number\": \"555-987-6543\",\n    \"page_url\": \"https://example.com/form\",\n    \"utm_source\": \"facebook\",\n    \"campaignid\": \"lead-gen\",\n    \"utm_medium\": \"social\",\n    \"utm_content\": \"post-1\",\n    \"how_can_we_help_you\": \"Interested in a consultation\",\n    \"casetype\": \"Auto Accident\"\n  }\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/{{rest_path}}/v1/publicapi/submissions",
          "host": ["{{base_url}}"],
          "path": ["{{rest_path}}", "v1", "publicapi", "submissions"]
        }
      },
      "description": "Payload with a \"data\" wrapper (e.g. PublicApi webhooks). Same canonical keys as the flat payload."
    },
    {
      "name": "Create Submission (with signature)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 or 401\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 401]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json", "type": "text"},
          {"key": "X-Api-Key", "value": "{{api_key}}", "type": "text"},
          {"key": "x-publicapi-signature", "value": "{{x_publicapi_signature}}", "type": "text", "description": "HMAC-SHA256 of raw body (hex). Set in pre-request or leave empty if no Webhook Secret."}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"signed@example.com\",\n  \"name\": \"Signed\",\n  \"last_name\": \"Request\",\n  \"phone_number\": \"555-000-0000\",\n  \"casetype\": \"Auto Accident\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/{{rest_path}}/v1/publicapi/submissions",
          "host": ["{{base_url}}"],
          "path": ["{{rest_path}}", "v1", "publicapi", "submissions"]
        }
      },
      "description": "When Public API Integration Config has a Webhook Secret, send x-publicapi-signature (HMAC-SHA256 of raw body, hex). If no secret, signature is optional."
    },
    {
      "name": "Create Submission – Invalid JSON (expect 400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test(\"Error message returned\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('errorMessage');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json", "type": "text"},
          {"key": "X-Api-Key", "value": "{{api_key}}", "type": "text"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{ invalid json }",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/{{rest_path}}/v1/publicapi/submissions",
          "host": ["{{base_url}}"],
          "path": ["{{rest_path}}", "v1", "publicapi", "submissions"]
        }
      },
      "description": "Sends invalid JSON to verify the API returns 400 with an error message."
    }
  ],
  "variable": [
    {"key": "record_id", "value": "", "type": "string"},
    {"key": "x_publicapi_signature", "value": "", "type": "string"}
  ]
}
