<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__HomePage">
            <property name="jsonString" type="String" label="JSON String" description="The JSON string to display."/>
            <property name="colorTheme" type="String" label="Color Theme" description="Valid values: default, warm, cool, or black."/>
        </targetConfig>
        <targetConfig targets="lightning__RecordPage">
            <property name="fieldApiName" type="String" label="Field API Name" description="Format: ObjectApiName.FieldApiName"/>
            <property name="jsonString" type="String" label="JSON String (Alternative)" description="Used when Field API Name is blank."/>
            <property name="colorTheme" type="String" label="Color Theme" description="Valid values: default, warm, cool, or black."/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
